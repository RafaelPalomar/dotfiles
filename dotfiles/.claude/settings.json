{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(notmuch-agent search:*)",
      "Bash(notmuch-agent show:*)",
      "Bash(notmuch-agent count:*)",
      "Bash(notmuch-agent address:*)",
      "Bash(notmuch-agent tag:*)",
      "Bash(mail-draft:*)",
      "Bash(lgogdownloader --check-login-status)",
      "Bash(lgogdownloader --list:*)",
      "Bash(lgogdownloader --download:*)",
      "Bash(lgogdownloader --update-check:*)",
      "Bash(lgogdownloader --repair:*)",
      "Bash(gog-install:*)"
    ],
    "deny": [
      "Bash(msmtp:*)",
      "Bash(sendmail:*)",
      "Bash(mutt_oauth2.py:*)",
      "Bash(mutt_oauth2:*)",
      "Bash(auth-email-ntnu:*)",
      "Bash(auth-email-uio:*)",
      "Bash(pass show email/*)",
      "Bash(pass show email/*:*)",
      "Bash(notmuch:*)",
      "Bash(notmuch search:*)",
      "Bash(notmuch show:*)",
      "Bash(notmuch count:*)",
      "Bash(notmuch address:*)",
      "Bash(notmuch tag:*)",
      "Bash(notmuch new:*)",
      "Bash(notmuch reply:*)",
      "Bash(notmuch config:*)",
      "Bash(notmuch restore:*)",
      "Bash(notmuch dump:*)",
      "Bash(notmuch reindex:*)",
      "Bash(notmuch insert:*)",
      "Bash(notmuch compact:*)",
      "Bash(mbsync:*)",
      "Bash(sync-mail:*)",
      "Bash(sync-mail-agent-index:*)",
      "Bash(lgogdownloader --login:*)",
      "Bash(lgogdownloader --gui-login:*)",
      "Bash(lgogdownloader --browser-login:*)",
      "Read(~/.config/lgogdownloader/**)",
      "Write(~/.config/lgogdownloader/**)",
      "Edit(~/.config/lgogdownloader/**)",
      "Read(~/.password-store/**)",
      "Read(~/.dotfiles/sops/**)",
      "Read(~/.local/share/mail/**)",
      "Read(~/.local/share/mail-agent/**)",
      "Read(~/.notmuch-config)",
      "Read(~/.notmuch-config-agent)",
      "Write(~/.local/share/mail/**)",
      "Write(~/.local/share/mail-agent/**)",
      "Edit(~/.local/share/mail/**)",
      "Edit(~/.local/share/mail-agent/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Host is GNU Guix System (entelequia dotfiles). Only packages declared in entelequia are installed. If a command is missing, do NOT say it is unavailable — run it ephemerally: `guix shell <pkg> -- <cmd>`. Combine packages by listing them (e.g. `guix shell jq ripgrep -- bash -c ...`). Build deps: `guix shell -D <pkg>`. Find a package: `guix search <keyword>` or `guix package -A <regex>`. apt/dnf/pacman/brew/pip install --user/npm install -g do not apply on this host — ignore any impulse to use them. System-wide installs are declarative: edit entelequia Scheme and run `sudo guix time-machine -C ~/.dotfiles/channels-lock.scm -- system reconfigure ...`.\"}}'"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostCompact\",\"additionalContext\":\"Reminder after compaction — Host is GNU Guix System (entelequia). Missing tools → `guix shell <pkg> -- <cmd>`. Do NOT say a tool is unavailable without trying guix shell first. No apt/dnf/pacman/brew/pip install --user/npm install -g on this host.\"}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/pks-commit-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/pks-stop-hook"
          }
        ]
      }
    ]
  }
}
